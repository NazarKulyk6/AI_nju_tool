# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# DB_HOST / DB_PORT — internal Docker connection (do not change).
DB_HOST=db                 # Internal DNS name of the PostgreSQL service
DB_PORT=5432               # Internal PostgreSQL port inside the container
DB_NAME=scraper            # Database name
DB_USER=postgres           # Database user
DB_PASSWORD=your_password_here  # Database password
# DB_HOST_PORT — host-side port for external tools (DBeaver/psql).
# Change if 5438 is already in use.
DB_HOST_PORT=5438

# ─── Web server ────────────────────────────────────────────────────────────────
# WEB_HOST_PORT — host-side port for the website (http://host:WEB_HOST_PORT).
# Change if 3001 is already in use.
WEB_HOST_PORT=3001

# ─── Redis (BullMQ queue) ──────────────────────────────────────────────────────
# REDIS_HOST / REDIS_PORT — internal Docker connection (do not change).
REDIS_HOST=redis           # Internal DNS name of Redis
REDIS_PORT=6379            # Internal Redis port inside the container

# REDIS_HOST_PORT — host-side Redis port.
# Change if 6379 is already in use.
REDIS_HOST_PORT=6379

# ─── G4F API ───────────────────────────────────────────────────────────────────
# G4F_HOST_PORT — host-side G4F API port (http://localhost:G4F_HOST_PORT/v1).
# Change if 1337 is already in use.
G4F_HOST_PORT=1337

# ─── AI Backend ────────────────────────────────────────────────────────────────
#
#  Two backends are supported for query suggestion and AI analysis:
#
#  AI_BACKEND=g4f     -> gpt4free (free, no API key needed)
#  AI_BACKEND=gemini  -> Google Gemini API (requires GEMINI_API_KEY)
#
#  Default: g4f
#
AI_BACKEND=g4f

# ── G4F (gpt4free) settings ────────────────────────────────────────────────────
# Relevant only when AI_BACKEND=g4f.
# Internal URL of the g4f service in Docker.
G4F_BASE_URL=http://g4f:8080/v1

# List of g4f providers in "Provider:model:max_concurrent" format, comma-separated.
# Providers are tried left-to-right.
# Example command to list available providers:
#   docker exec njuskalo_g4f python3 -c \
#     "import g4f.Provider as P, inspect; [print(n) for n,o in inspect.getmembers(P,inspect.isclass) if getattr(o,'needs_auth',None) is False]"
G4F_PROVIDERS=PollinationsAI:openai-fast:1,Yqcloud:gpt-4:3

# Provider is paused after N consecutive failures.
G4F_FAILURE_THRESHOLD=3
# Seconds before retrying a paused provider.
G4F_RESET_AFTER_SEC=300
# Timeout for a single provider call (seconds).
G4F_CALL_TIMEOUT=60
# Number of retries for one provider within a single request.
G4F_MAX_RETRIES=2

# Informational model names for analyzer/suggest.
G4F_ANALYZER_MODEL=openai-fast
G4F_SUGGEST_MODEL=openai-fast

# ── Gemini API settings ────────────────────────────────────────────────────────
# Relevant only when AI_BACKEND=gemini.
# Get API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini models for listing analysis (comma-separated, by priority).
GEMINI_ANALYZER_MODELS=gemma-3-27b-it,gemma-3-12b-it,gemini-3.1-flash-lite-preview,gemini-2.5-flash

# Gemini models for search-query generation.
GEMINI_SUGGEST_MODELS=gemini-3.1-flash-lite-preview,gemma-3-27b-it,gemini-2.5-flash,gemma-3-12b-it

# Retry count for model-level transient 429 rate limits.
GEMINI_RETRY_ATTEMPTS=4

# ── Shared AI settings ─────────────────────────────────────────────────────────
# Number of parallel AI analyzer workers.
# For g4f: usually 3-5. For gemini: prefer 1.
AI_CONCURRENCY=3

# Delay between AI calls inside each worker (ms).
AI_CALL_DELAY_MS=300

# ─── Scraper parallelism ───────────────────────────────────────────────────────
# Number of browser tabs parsing listing pages in parallel (Stage 2).
# 1 = safer, 2-4 = faster, 5+ = higher blocking risk.
SCRAPER_CONCURRENCY=3

# ─── Anti-detection: Browser ───────────────────────────────────────────────────

# Browser mode:
# false = visible via Xvfb (harder to detect, slower)
# true  = headless (faster, easier to detect)
SCRAPER_HEADLESS=false

# Browser locale (affects Accept-Language and navigator.language).
BROWSER_LOCALE=hr-HR

# Browser timezone (affects Date/timezone detection).
BROWSER_TIMEZONE=Europe/Zagreb

# ─── Anti-detection: Delays (milliseconds) ────────────────────────────────────
# All delays below are randomized within MIN..MAX.

# Delay after loading search results page before collecting links.
DELAY_AFTER_RESULTS_PAGE_MIN=1500
DELAY_AFTER_RESULTS_PAGE_MAX=3000

# Delay between search results pages.
DELAY_BETWEEN_PAGES_MIN=2000
DELAY_BETWEEN_PAGES_MAX=5000

# Delay before opening the next listing.
DELAY_BETWEEN_LISTINGS_MIN=500
DELAY_BETWEEN_LISTINGS_MAX=2000

# Delay after opening listing page before data extraction.
DELAY_AFTER_LISTING_MIN=1000
DELAY_AFTER_LISTING_MAX=2500

# ─── Anti-detection: Retry ────────────────────────────────────────────────────

# How many times to retry failed page request.
RETRY_MAX_ATTEMPTS=3

# Base delay before retry (multiplied on each next attempt).
RETRY_BASE_DELAY_MS=3000
