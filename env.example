# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# DB_HOST / DB_PORT — how the app connects inside Docker (DO NOT change).
DB_HOST=db                 # Docker service hostname (always "db" inside Docker)
DB_PORT=5432               # Internal container port (always 5432 inside Docker)
DB_NAME=scraper            # Database name
DB_USER=postgres           # Database user
DB_PASSWORD=your_password_here  # Database password
# DB_HOST_PORT — host-side port for external tools (DBeaver, psql, etc.)
# Change if 5438 is already taken on the host.
DB_HOST_PORT=5438

# ─── Web server ────────────────────────────────────────────────────────────────
# WEB_HOST_PORT — host-side port the browser connects to.
# Change if 3001 is already taken on the host.
WEB_HOST_PORT=3001

# ─── Redis (BullMQ job queue) ──────────────────────────────────────────────────
# REDIS_HOST / REDIS_PORT — hostname and port the app connects to (inside Docker network).
# Keep REDIS_HOST=redis and REDIS_PORT=6379 (Docker internal — don't change unless you
# run Redis externally).
REDIS_HOST=redis
REDIS_PORT=6379

# REDIS_HOST_PORT — host-side port exposed to the outside world.
# Change this if port 6379 is already taken on the host (e.g. another Redis instance).
REDIS_HOST_PORT=6379

# ─── G4F API ───────────────────────────────────────────────────────────────────
# G4F_HOST_PORT — host-side port for the G4F API (http://localhost:G4F_HOST_PORT/v1).
# Change if 1337 is already taken on the host.
G4F_HOST_PORT=1337

# ─── AI Backend ────────────────────────────────────────────────────────────────
#
#  Two backends are supported for query suggestion and listing analysis:
#
#  AI_BACKEND=g4f     → gpt4free (FREE — no API key needed, uses the g4f Docker service)
#  AI_BACKEND=gemini  → Google Gemini API (requires GEMINI_API_KEY below)
#
#  Default: g4f  (recommended — no quota limits, no key required)
#
AI_BACKEND=g4f

# ── G4F (gpt4free) settings ────────────────────────────────────────────────────
# Only relevant when AI_BACKEND=g4f.
# The g4f Docker service runs an OpenAI-compatible API at this URL.
# Inside Docker: http://g4f:8080/v1 (default).
# Local dev (outside Docker): http://localhost:1337/v1
G4F_BASE_URL=http://g4f:8080/v1

# Comma-separated list of free g4f providers to try in order.
# Format: "Provider:model,Provider:model,..."
# The bridge tries each pair left-to-right with circuit-breaker protection.
# The model name in each pair is provider-specific (NOT an OpenAI model name).
#
# To list all available free providers:
#   docker exec njuskalo_g4f python3 -c \
#     "import g4f.Provider as P, inspect; [print(n) for n,o in inspect.getmembers(P,inspect.isclass) if getattr(o,'needs_auth',None) is False]"
G4F_PROVIDERS=PollinationsAI:openai-fast:1,Yqcloud:gpt-4:3

# Circuit-breaker: after this many consecutive failures a provider is paused
G4F_FAILURE_THRESHOLD=3
# Seconds to wait before auto-retrying a tripped provider
G4F_RESET_AFTER_SEC=300
# Per-call timeout in seconds (one provider attempt)
G4F_CALL_TIMEOUT=60
# Retry attempts per provider within a single request (before moving to the next)
G4F_MAX_RETRIES=2

# These are sent as the "model" field to the bridge but the bridge uses
# the model defined in G4F_PROVIDERS above — these values are informational.
G4F_ANALYZER_MODEL=openai-fast
G4F_SUGGEST_MODEL=openai-fast

# ── Gemini API settings ────────────────────────────────────────────────────────
# Only relevant when AI_BACKEND=gemini.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of Gemini models to try (in order) for listing analysis.
# Falls back to the next model if one hits a hard quota (limit: 0).
# Highest free-tier RPD first: gemma-3-27b-it = 14,400/day; gemini-2.5-flash = 20/day
GEMINI_ANALYZER_MODELS=gemma-3-27b-it,gemma-3-12b-it,gemini-3.1-flash-lite-preview,gemini-2.5-flash

# Comma-separated list of Gemini models to try for query suggestion.
GEMINI_SUGGEST_MODELS=gemini-3.1-flash-lite-preview,gemma-3-27b-it,gemini-2.5-flash,gemma-3-12b-it

# Max retry attempts per model on transient 429 errors (exponential back-off: 2s→4s→8s→16s)
GEMINI_RETRY_ATTEMPTS=4

# ── Shared AI settings ─────────────────────────────────────────────────────────
# How many listings to analyze in parallel (BullMQ worker concurrency).
# G4F: 3–5 is safe and gives 3–5× speedup.
# Gemini: keep at 1 (strict 30 RPM rate limit).
AI_CONCURRENCY=3

# Delay between AI calls per worker (ms).
# G4F: 300ms is enough.  Gemini: keep ≥2000 (30 RPM limit).
AI_CALL_DELAY_MS=300

# ─── Anti-detection: Browser ───────────────────────────────────────────────────

# Whether to run the browser in headless mode (no visible window)
# false = browser window is visible via Xvfb (required inside Docker, harder to detect)
# true  = fully headless, faster but easier for sites to detect
SCRAPER_HEADLESS=false

# Browser locale — affects the Accept-Language request header and navigator.language
# Use the locale of the target site (Croatian) to look like a local user
BROWSER_LOCALE=hr-HR

# Browser timezone — affects JavaScript Date objects and timezone detection
# Should match the locale above
BROWSER_TIMEZONE=Europe/Zagreb

# ─── Anti-detection: Delays (milliseconds) ────────────────────────────────────
# All delays are random within the MIN–MAX range to simulate human behaviour.
# Increase values to be more cautious; decrease to scrape faster.

# How long to wait after a search-results page loads before collecting links
# (gives the page time to fully render and looks more human)
DELAY_AFTER_RESULTS_PAGE_MIN=1500
DELAY_AFTER_RESULTS_PAGE_MAX=3000

# How long to wait between navigating to the next search-results page
# (pause between pagination clicks)
DELAY_BETWEEN_PAGES_MIN=2000
DELAY_BETWEEN_PAGES_MAX=5000

# How long to wait before opening the next individual listing
# (pause between listing requests — the main throttle knob)
DELAY_BETWEEN_LISTINGS_MIN=500
DELAY_BETWEEN_LISTINGS_MAX=2000

# How long to wait after a listing page loads before extracting its data
# (gives dynamic content time to render)
DELAY_AFTER_LISTING_MIN=1000
DELAY_AFTER_LISTING_MAX=2500

# ─── Anti-detection: Retry ────────────────────────────────────────────────────

# How many times to retry a failed page request before giving up
RETRY_MAX_ATTEMPTS=3

# Base wait time before the first retry (doubles each attempt: 3s → 6s → 12s)
RETRY_BASE_DELAY_MS=3000
